{
  "manifest_version": 3,
  "name": "GocTruyenTranhVui Follow Exporter",
  "version": "0.1.0",
  "author": "DZ0Phong",
  "description": "Xuất danh sách truyện đang theo dõi và tiến độ đọc ra file CSV.",
  "permissions": [
    "tabs"
  ],
  "host_permissions": [
    "*://goctruyentranhvui23.com/*"
  ],
  "action": {
    "default_title": "Manga Exporter",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://goctruyentranhvui23.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
